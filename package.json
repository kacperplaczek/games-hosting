{
  "name": "games-hosting",
  "version": "0.0.1",
  "description": "",
  "scripts": {
    "dev": "pnpm run dev:all",
    "dev:all": "pnpm --parallel --filter client-panel --filter support-panel --filter website --filter api dev",
    "dev:cp": "pnpm --filter client-panel dev",
    "dev:sp": "pnpm --filter support-panel dev",
    "dev:web": "pnpm --filter website dev",
    "dev:api": "pnpm --filter api start:dev",

    "build": "pnpm run build:all",
    "build:all": "pnpm --filter client-panel --filter support-panel --filter website --filter api build",
    "build:front-end": "pnpm --filter client-panel --filter support-panel --filter website build",
    "build:cp": "pnpm --filter client-panel build",
    "build:sp": "pnpm --filter support-panel build",
    "build:web": "pnpm --filter website build",
    "build:api": "pnpm --filter api build",

    "start": "pnpm run start:all",
    "start:all": "pnpm --parallel --filter client-panel --filter support-panel --filter website --filter api start",
    "start:cp": "pnpm --filter client-panel start",
    "start:sp": "pnpm --filter support-panel start",
    "start:web": "pnpm --filter website start",
    "start:api": "pnpm --filter api start:prod",

    "lint": "pnpm --filter client-panel --filter support-panel --filter website --filter api lint",
    "lint:cp": "pnpm --filter client-panel lint",
    "lint:sp": "pnpm --filter support-panel lint",
    "lint:web": "pnpm --filter website lint",
    "lint:api": "pnpm --filter api lint"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2"
}
